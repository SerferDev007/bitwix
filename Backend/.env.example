# Server
PORT=5000
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173

# Default display currency for the admin console (INR or USD).
DEFAULT_CURRENCY=INR

# MySQL connection (local dev). In production point these at the RDS endpoint.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bitwix

# --- Production / RDS options ---
# Enable TLS to the database (set to true for RDS).
DB_SSL=false
# Set false if you don't bundle the RDS CA (traffic still encrypted).
DB_SSL_REJECT_UNAUTHORIZED=true
# Startup: retry the DB connection this many times before exiting.
DB_CONNECT_RETRIES=10
# First deploy only: create + seed the schema on boot, then set back to false.
RUN_DB_INIT=false

# Admin console login. CHANGE THESE before deploying.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bitwix123
# Secret used to sign login tokens. Set to a long random string in production.
AUTH_SECRET=change-me-to-a-long-random-string
