# Server
PORT=5000
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173

# Default display currency for the admin console (INR or USD).
DEFAULT_CURRENCY=INR

# MySQL connection (local dev). In production point these at the RDS endpoint.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bitwix

# --- Production / RDS options ---
# Enable TLS to the database (set to true for RDS).
DB_SSL=false
# Set false if you don't bundle the RDS CA (traffic still encrypted).
DB_SSL_REJECT_UNAUTHORIZED=true
# Startup: retry the DB connection this many times before exiting.
DB_CONNECT_RETRIES=10
# First deploy only: create + seed the schema on boot, then set back to false.
RUN_DB_INIT=false
# Ledger reconcile sweep interval (seconds). Re-drives any dropped auto-post.
# Defaults to 600 in production, disabled elsewhere. Set 0 to disable.
RECONCILE_INTERVAL_SEC=600

# Media uploads (team photos) to S3. Leave MEDIA_BUCKET empty to disable uploads.
# In production the App Runner instance role must allow s3:PutObject on this bucket.
MEDIA_BUCKET=
MEDIA_REGION=ap-south-1
# Optional public base URL (e.g. a CloudFront/CDN domain). Defaults to the S3 URL.
MEDIA_PUBLIC_BASE_URL=

# Admin console login. CHANGE THESE before deploying.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bitwix123
# Token signing secrets — MUST all be set to DISTINCT long random strings in
# production. If HR_AUTH_SECRET / CRM_AUTH_SECRET are left unset they fall back to
# AUTH_SECRET, meaning every plane (admin, CRM staff, CRM portal, HR) signs with
# the same key. requireAuth now rejects cross-plane tokens on admin/finance
# routes regardless, but sharing a signing key across planes is still weak — give
# each its own.
AUTH_SECRET=change-me-to-a-long-random-string

# Employee Management System (RBAC/HR) — bootstrap Super Admin + token secret.
HR_BOOTSTRAP_EMAIL=superadmin@bitwix.co.in
HR_BOOTSTRAP_PASSWORD=ChangeMe-superadmin-123
HR_AUTH_SECRET=change-me-to-a-long-random-hr-secret

# CRM (dual-plane) — bootstrap internal Super Admin + token secret.
CRM_BOOTSTRAP_EMAIL=crmadmin@bitwix.co.in
CRM_BOOTSTRAP_PASSWORD=ChangeMe-crmadmin-123
CRM_AUTH_SECRET=change-me-to-a-long-random-crm-secret
