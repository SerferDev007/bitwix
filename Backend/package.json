{
  "name": "bitwix-backend",
  "version": "1.0.0",
  "description": "Backend API for the Bitwix Technologies website (Express + MySQL)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:init": "node src/scripts/initDb.js",
    "test:or": "node src/or/validate.mjs",
    "test:hr": "node src/hr/validate.mjs",
    "test:crm": "node src/crm/validate.mjs",
    "test:api": "node src/scripts/integrationTest.mjs",
    "test": "node src/or/validate.mjs && node src/hr/validate.mjs && node src/crm/validate.mjs && node src/scripts/integrationTest.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5"
  }
}
