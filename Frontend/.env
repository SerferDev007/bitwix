# Origin-relative API base — the Vite dev server proxies /api to the backend
# (see vite.config.ts). In production, serve the built app behind the same
# origin as the API and this keeps working with no change.
VITE_API_URL=/api

# Where the dev proxy forwards /api requests. Change if the backend runs
# on a different host/port.
VITE_BACKEND_ORIGIN=http://localhost:5000
